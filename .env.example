# ============================================================
# acervo-extractor-quant  —  environment variables
# Copy this file to .env and fill in the values you need.
# ============================================================

# ------------------------------------------------------------------
# Model selection
# ------------------------------------------------------------------

# HuggingFace model ID to quantize (the "target" model in reports).
# Change this to any causal-LM available on the Hub.
MODEL_ID=SandyVeliz/acervo-extractor-qwen3.5-9b

# Model used for the demo / baseline benchmark (should be small enough
# to run on CPU — gpt2 = 124M params, ~250 MB).
DEMO_MODEL=openai-community/gpt2

# Model used in benchmark.py as the float16 baseline.
BENCHMARK_MODEL=openai-community/gpt2

# Comma-separated list of models for compare.py (side-by-side comparison).
# Use small CPU-friendly models for quick runs.
COMPARE_MODELS=openai-community/gpt2,facebook/opt-125m

# ------------------------------------------------------------------
# HuggingFace credentials (optional — only needed for gated models)
# ------------------------------------------------------------------

# Personal access token from https://huggingface.co/settings/tokens
# Required to download private or gated models (e.g. Llama-3, Mistral).
HF_TOKEN=

# Local directory for the HuggingFace model cache.
# Defaults to <output_dir>/model_cache when unset.
HF_CACHE_DIR=

# ------------------------------------------------------------------
# llama.cpp paths
# ------------------------------------------------------------------

# Local path where llama.cpp will be cloned / found.
LLAMA_CPP_PATH=llama.cpp

# Git URL to clone llama.cpp from.
LLAMA_CPP_REPO=https://github.com/ggerganov/llama.cpp

# ------------------------------------------------------------------
# Output paths
# ------------------------------------------------------------------

# Directory for GGUF files and quantization metadata (quantize.py).
OUTPUT_DIR=output

# Directory for demo and benchmark output files.
OUTPUTS_DIR=outputs

# Path for the Markdown report (benchmark.py).
REPORT_PATH=quantization_report.md

# Path for the JSON benchmark results (benchmark.py).
RESULTS_JSON=benchmark_results.json

# ------------------------------------------------------------------
# Benchmark parameters
# ------------------------------------------------------------------

# Number of prompts used for perplexity evaluation.
NUM_PROMPTS=100

# Max new tokens generated per prompt during speed measurement.
MAX_NEW_TOKENS=50

# Number of prompts used in demo.py (smaller for quick demo runs).
NUM_DEMO_PROMPTS=20

# Number of warmup generation passes before timed measurement.
# Warmup avoids cold-start bias in latency measurements.
WARMUP_RUNS=2

# Quantization types to produce (comma-separated llama.cpp type names).
# Run `python quantize.py --list-quant-types` to see all options.
QUANT_TYPES=Q4_K_M,Q8_0

# ------------------------------------------------------------------
# Download retry settings (quantize.py)
# ------------------------------------------------------------------

# Number of retry attempts on transient HuggingFace download errors.
RETRY_ATTEMPTS=3

# Initial backoff in seconds (doubles on each retry).
RETRY_BACKOFF=2.0

# ------------------------------------------------------------------
# Demo / dry-run flags
# ------------------------------------------------------------------

# Set to 1 / true to force mock mode in demo.py (no model download).
DEMO_DRY_RUN=
